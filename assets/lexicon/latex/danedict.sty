\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{danedict}[2026/04/12 Danetian dictionary macros]

% Engine: XeLaTeX or LuaLaTeX recommended.
\RequirePackage{xparse}
\RequirePackage{fontspec}
\RequirePackage{polyglossia}
\RequirePackage{imakeidx}
\RequirePackage{reledmac}
\RequirePackage{microtype}
\RequirePackage{enumitem}
\RequirePackage{etoolbox}
\RequirePackage{xcolor}
\RequirePackage{hyperref}
\RequirePackage{geometry}
\RequirePackage{fancyhdr}
\RequirePackage{setspace}

% ---------- Page/layout ----------
\geometry{
  paperwidth=6in,
  paperheight=9in,
  inner=0.75in,
  outer=0.65in,
  top=0.75in,
  bottom=0.8in,
  headheight=14pt
}

\setstretch{1.03}
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.2em}

\pagestyle{fancy}
\fancyhf{}
\fancyhead[LE]{\footnotesize\itshape \leftmark}
\fancyhead[RO]{\footnotesize\itshape \rightmark}
\fancyfoot[C]{\thepage}

\hypersetup{
  colorlinks=true,
  linkcolor=black,
  urlcolor=black,
  citecolor=black
}

% ---------- Fonts ----------
% Replace these with your preferred installed fonts if needed.
\setmainfont{Libertinus Serif}
\newfontfamily\danetianfont{Libertinus Serif}
\newfontfamily\foreignfont{Libertinus Serif}
\newfontfamily\greekfont{Libertinus Serif}
\newfontfamily\cyrillicfont{Libertinus Serif}
\newfontfamily\arabicfont[Script=Arabic]{Amiri}

\setdefaultlanguage{english}
\setotherlanguages{greek,russian,arabic}

% ---------- Index ----------
\makeindex[name=dan,title=Danetian--English Dictionary]
% Uncomment later if you generate a reverse index:
% \makeindex[name=eng,title=English--Danetian Index]

% ---------- Internal state ----------
\newcounter{dictsense}
\newif\ifinentry
\inentryfalse

\newcommand{\dictentrybreak}{%
  \par\vspace{0.45\baselineskip}%
}

\newcommand{\dictreset}{%
  \setcounter{dictsense}{0}%
}

% ---------- Entry macros ----------
\NewDocumentCommand{\mykey}{m}{%
  \ifinentry\dictentrybreak\fi
  \inentrytrue
  \dictreset
  \markboth{#1}{#1}%
  \index[dan]{#1}%
  {\danetianfont\bfseries #1.}%
}

\NewDocumentCommand{\myexpr}{m}{%
  \ifinentry\dictentrybreak\fi
  \inentrytrue
  \dictreset
  \markboth{#1}{#1}%
  \index[dan]{#1}%
  {\danetianfont\bfseries #1}%
  \nobreak\hspace{0.5em}%
  {\footnotesize\scshape expr.}%
}

\NewDocumentCommand{\myety}{m}{%
%  \par
%  \hangindent=2em\hangafter=1
%  \hspace*{1.2em}
	{\footnotesize [\textit{#1}]}%
}

\NewDocumentCommand{\myinfl}{o m}{%
%  \nobreak\hspace{0.6em}%
%  {\footnotesize\color{gray}%
%    \IfNoValueTF{#1}
%      {[infl.\ #2]}
%      {[infl.\ class~#1: #2]}%
%  }%
}

\NewDocumentCommand{\mytyp}{m}{%
  \nobreak%\hspace{0.6em}%
  %{\footnotesize\scshape #1}%
  \textit{#1.}
}

\NewDocumentCommand{\mylink}{m}{%
%  \par
%  \hangindent=2em\hangafter=1
%  \hspace*{1.2em}{\footnotesize\itshape Cf. forms}~#1%
}

\NewDocumentCommand{\mydef}{o m}{%
%  \par
%  \hangindent=2em\hangafter=1
  \stepcounter{dictsense}%
%  \hspace*{1.2em}%
  \IfNoValueTF{#1}
    {\textbf{\makebox[1.8em][l]{\footnotesize\arabic{dictsense}.}}}
    {\textbf{\makebox[1.8em][l]{\footnotesize#1.}}}%
  #2%
}

% ---------- Inline semantic/usage macros ----------
\NewDocumentCommand{\mypar}{m}{%
%  {\space\textnormal{\footnotesize\itshape #1}}%
  \textit{#1}
}

\NewDocumentCommand{\myfield}{m}{%
  {\footnotesize\textsc{#1}}\nobreakspace
}

\NewDocumentCommand{\myreg}{m}{%
  {\footnotesize\textsc{#1}}\nobreakspace
}

\NewDocumentCommand{\mygloss}{m}{%
  \emph{#1}%
}

\NewDocumentCommand{\mysilentgloss}{m}{%
  {\color{gray}\emph{#1}}%
}

\NewDocumentCommand{\myex}{m m}{%
%  \par
%  \hspace*{2.7em}%
  {\footnotesize\textquotedblleft #1\textquotedblright\enspace---\enspace#2}%
}

% ---------- Small utility tags ----------
\NewDocumentCommand{\mycf}{}{%
  \textit{cf.}\space
}

\NewDocumentCommand{\myetc}{}{%
  \textit{etc.}%
}

\NewDocumentCommand{\myunknown}{}{%
  \textit{unknown origin}%
}

\NewDocumentCommand{\mychem}{m}{%
%  {\footnotesize\textsc{el.~#1}}%
  \mypar{chemical element with atomic number~#1}
}

% ---------- Source-language / label tags ----------
% 1-arg forms
\NewDocumentCommand{\mylat}{m}{{\foreignfont\textit{Lat.}~#1}}
\NewDocumentCommand{\mypie}{m}{{\foreignfont\textit{PIE}~#1}}
\NewDocumentCommand{\mydnt}{m}{{\danetianfont #1}}
\NewDocumentCommand{\myeng}{m}{{\foreignfont\textit{Eng.}~#1}}
\NewDocumentCommand{\myfra}{m}{{\foreignfont\textit{Fr.}~#1}}
\NewDocumentCommand{\myger}{m}{{\foreignfont\textit{Ger.}~#1}}
\NewDocumentCommand{\myita}{m}{{\foreignfont\textit{It.}~#1}}
\NewDocumentCommand{\mybg}{m}{{\foreignfont\textit{Bulg.}~#1}}
\NewDocumentCommand{\mycat}{m}{{\foreignfont\textit{Cat.}~#1}}
\NewDocumentCommand{\mydan}{m}{{\foreignfont\textit{Dan.}~#1}}
\NewDocumentCommand{\mykyr}{m}{{\foreignfont\textit{Kyrg.}~#1}}
\NewDocumentCommand{\myono}{}{{\textit{onom.}}}
\NewDocumentCommand{\myprotrk}{m}{{\foreignfont\textit{Proto-Turkic}~#1}}
\NewDocumentCommand{\myprotung}{m}{{\foreignfont\textit{Proto-Tungusic}~#1}}
\NewDocumentCommand{\myara}{m m}{{\textit{Ar.}~\textarabic{#1}~\emph{#2}}}
\NewDocumentCommand{\myper}{m m}{{\textit{Pers.}~\textarabic{#1}~\emph{#2}}}
\NewDocumentCommand{\mygrc}{m m}{{\textit{Gk.}~\textgreek{#1}~\emph{#2}}}
\NewDocumentCommand{\myrus}{m m}{{\textit{Rus.}~{\cyrillicfont #1}~\emph{#2}}}

% ---------- Fallbacks for future macros ----------
% These are harmless placeholders so the document compiles even if your exporter
% emits tags you have not styled yet.
\NewDocumentCommand{\mysyn}{m}{%
  \par\hangindent=2em\hangafter=1
  \hspace*{1.2em}{\footnotesize\itshape Syn.}~#1%
}

\NewDocumentCommand{\mylinknote}{m}{%
  \par\hangindent=2em\hangafter=1
  \hspace*{1.2em}{\footnotesize\itshape Note}~#1%
}
